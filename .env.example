POSTGRES_DB=leasetrack_dev
POSTGRES_USER=leasetrack_app
POSTGRES_PASSWORD=local-dev-postgres-password
POSTGRES_PORT=5432
RABBITMQ_USERNAME=leasetrack_app
RABBITMQ_PASSWORD=local-dev-rabbitmq-password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
APP_PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
APP_ACTUATOR_EXPOSED_ENDPOINTS=health,info
APP_HEALTH_SHOW_DETAILS=never
# Local development only. Production must set a random secret of at least 32 bytes.
APP_JWT_SECRET=local-dev-jwt-secret-change-before-use-32-bytes-min
APP_TRACKING_PROVIDER=mock
APP_TRACKING_CANADA_POST_ENABLED=false
APP_TRACKING_CANADA_POST_USERNAME=
APP_TRACKING_CANADA_POST_PASSWORD=
APP_TRACKING_FEDEX_ENABLED=false
APP_TRACKING_FEDEX_CLIENT_ID=
APP_TRACKING_FEDEX_CLIENT_SECRET=
APP_STORAGE_PROVIDER=s3
APP_LOCAL_STORAGE_ROOT=./data/evidence-documents
APP_STORAGE_S3_BUCKET=lease-track-evidence-prod
APP_STORAGE_S3_REGION=us-east-2
APP_STORAGE_S3_PREFIX=evidence-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
